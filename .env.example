# =============================================================================
# .env.example — copia este archivo a .env.development o .env.production
# =============================================================================

# --- Supabase Postgres ---
# DATABASE_URL: conexión directa (puerto 5432). Usado por pg_dump/pg_restore.
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres

# DATABASE_POOLER_URL: pooler (puerto 6543). Usado por scripts Node.
DATABASE_POOLER_URL=postgresql://postgres.PROJECT:PASSWORD@aws-0-us-west-1.pooler.supabase.com:6543/postgres

# --- SQL Server (AdminPAQ) ---
SQL_SERVER_HOST=HOST_O_IP
SQL_SERVER_PORT=1433
SQL_SERVER_USER=usuario
SQL_SERVER_PASSWORD=password

# --- Opcional: overrides para el script de backup ---
# Fecha mínima desde la que se exporta income_transactions (YYYY-MM-DD)
# INCOME_TRANSACTIONS_MIN_DATE=2026-01-01
